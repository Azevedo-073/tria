# ─── Google Gemini (AI Studio - free tier) ──
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# ─── Obsidian Local REST API ────────────────
# Settings → Community Plugins → Local REST API → API Key
OBSIDIAN_API_KEY=your_obsidian_key_here
OBSIDIAN_URL=https://127.0.0.1:27124

# ─── Gmail OAuth ────────────────────────────
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.pickle

# ─── Obsidian vault location ────────────────
VAULT_PATH=C:\path\to\your\obsidian\vault
